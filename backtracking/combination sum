class Solution {
public:
    vector<vector<int>> res;

    void solve(int index, int target, vector<int>& candidates, vector<int>& temp) {
        // Base Case 1: Agar target 0 ho gaya, toh result mil gaya
        if (target == 0) {
            res.push_back(temp);
            return;
        }

        // Base Case 2: Agar index boundary cross kar gaya ya target negative ho gaya
        if (index == candidates.size() || target < 0) {
            return;
        }

        // 1. PICK the current element 
        // (index same rakhenge kyunki same element baar-baar le sakte hain)
        temp.push_back(candidates[index]);
        solve(index, target - candidates[index], candidates, temp);

        // 2. NON-PICK (Backtrack)
        // (Element ko nikaalo aur agle index par jao)
        temp.pop_back();
        solve(index + 1, target, candidates, temp);
    }

    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<int> temp;
        solve(0, target, candidates, temp);
        return res;
    }
};

m-2= for loop se backtracking--------------------------------------------------------------------------------->
class Solution {
public:
    vector<vector<int>> res;

    void solve(int index, int target, vector<int>& candidates, vector<int>& temp) {
        // Base Case: Agar target 0 ho gaya, toh combinations mil gaya
        if (target == 0) {
            res.push_back(temp);
            return;
        }

        // Loop current index se lekar candidates ke end tak chalega
        for (int i = index; i < candidates.size(); i++) {
            // Optimization: Agar current element target se bada hai, 
            // aur array sorted hai, toh aage check karne ki zaroorat nahi hai (Optional)
            if (candidates[i] > target) {
                continue; // Ya fir 'break' agar candidates sorted ho
            }

            // 1. Element ko temp mein daalo
            temp.push_back(candidates[i]);

            // 2. Recursion call (index 'i' hi pass karenge kyunki same element repeat ho sakta hai)
            solve(i, target - candidates[i], candidates, temp);

            // 3. Backtrack (Element ko nikaalo taaki dusre combinations check ho sakein)
            temp.pop_back();
        }
    }

    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<int> temp;
        // Agar aap array ko sort kar doge, toh `candidates[i] > target` par direct 'break' kar sakte ho, 
        // jisse code aur fast ho jayega.
        // sort(candidates.begin(), candidates.end()); 
        
        solve(0, target, candidates, temp);
        return res;
    }
};

