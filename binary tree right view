class Solution {
public:
    vector<int> rightSideView(TreeNode* root) {
        //at page 1
        if(root==NULL)  return {};
        vector<int>res;
        queue<TreeNode*>que;
        que.push(root);

        while(!que.empty()){

            int n=que.size();
            TreeNode* node=NULL;

            while(n--){
               node=que.front();
               que.pop();

               if(node->left!=NULL)
                que.push(node->left);
               
               if(node->right!=NULL)
                que.push(node->right);//we have to find right most node at every level thats why we add right child after adding left child
               
            }
            res.push_back(node->val);
        }

        return res;
    }
};

//approach->2
class Solution {
public:
void preorder(TreeNode* root,int level,vector<int>&res){
    if(root==NULL) return;

    if(res.size()<level){
        res.push_back(root->val);
    }
    
    preorder(root->right,level+1,res);
    preorder(root->left,level+1,res);

}
    vector<int> rightSideView(TreeNode* root) {
        //using preorder traversal or root->right->left;
          vector<int>res;
          preorder(root,1,res);//1 is level
          return res;
    }

};/*Aapka input jo TreeNode* root hai usmein bahut saare nodes store nahin hain.
Uske andar sirf ek cheez store hai: topmost node ka address phir us topmost node ke address ke through hum aur nodes visit karte hain.
TreeNode *root means root represents topmost node */

