class Solution {
  public:
    bool canAttend(vector<vector<int>> &arr) {
        // Code Here
        int n=arr.size();
        sort(arr.begin(),arr.end());
         int prevEnd = arr[0][1];
        for(int i=1;i<n;i++){
           int currStart = arr[i][0];
            int currEnd = arr[i][1];
            
            // If the current meeting starts before the previous one ends, conflict!
            if (currStart < prevEnd) {
                return false;
            }
            
            // Update the previous end time to the current meeting's end time
            prevEnd = currEnd;
        }
        return true;
    }
};

