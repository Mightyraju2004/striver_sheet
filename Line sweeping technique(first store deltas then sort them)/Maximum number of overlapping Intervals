class Solution {
  public:
    int overlapInt(vector<vector<int>> &arr) {
        // code here
        map<int, int> events;//ordered map sorted ascending order mai store karta hai keys ko
        int n = arr.size();
        
        for(int i = 0; i < n; i++){
            // +1 means interval start
            events[arr[i][0]]++; 
            
            // -1 means interval end (par 1 second ki deri se taaki overlap miss na ho)
            events[arr[i][1] + 1]--; 
        }

        int max_overlap = 0;
        int current_overlap = 0;

        //ordered map sorted order me loop chalayega
        for (const auto& event : events) {
            // current_overlap me +1 ya -1 add hota jayega
            current_overlap += event.second; 
            
            // ab tak ka maximum overlap track ho rha hai
            max_overlap = max(max_overlap, current_overlap);
        }

        return max_overlap;
    }
};
