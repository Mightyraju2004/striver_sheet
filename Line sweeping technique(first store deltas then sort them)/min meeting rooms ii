class Solution {
  public:
    int minMeetingRooms(vector<int> &start, vector<int> &end) {
        map<int,int>events;
        int n=start.size();
        for(int i=0;i<n;i++){
            events[start[i]]++;
            events[end[i]]--;
        }
        int curr_rooms=0;
        int max_rooms=0;
        for(auto &it:events){
            curr_rooms+=it.second;
            max_rooms=max(max_rooms,curr_rooms);
        }
        return max_rooms;
    }
};
