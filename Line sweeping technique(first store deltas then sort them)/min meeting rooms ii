//maxoverlap=min meeting rooms required
class Solution {
  public:
    int minMeetingRooms(vector<int> &start, vector<int> &end) {
        map<int,int>events;
        int n=start.size();
        for(int i=0;i<n;i++){
            events[start[i]]++;
            events[end[i]]--;
        }
        int curr_overlap=0;
        int max_overlap=0;
        for(auto &it:events){
            curr_overlap+=it.second;
            max_overlap=max(max_overlap,curr_overlap);
        }
        return max_overlap;
    }
};
