class Solution {
public:
    int findContentChildren(vector<int>& g, vector<int>& s) {
        //array s is size of cookie ka array
        int m=g.size();
        int n=s.size();
        sort(s.begin(),s.end());
        sort(g.begin(),g.end());
         int i=0,j=0;//i is greed waala index, j is size of cookie waale array ka index
         while(i<m && j<n){
            if(s[j]>=g[i]) i++;//iski to fulfill hogyi now check for next i(next element greed condition fulfill or not)
            j++;//cookie ko aage badhao
         }
        return i;
    }
};
