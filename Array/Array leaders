class Solution {
  public:
    vector<int> leaders(vector<int>& arr) {
        int n = arr.size();
        vector<int> ans;
        
        // Rightmost element is always a leader
        int max_from_right = arr[n - 1];
        ans.push_back(max_from_right);
        
        // Traverse the array from right to left (second last element to first)
        for (int i = n - 2; i >= 0; i--) {
            if (arr[i] >= max_from_right) {
                max_from_right = arr[i];
                ans.push_back(arr[i]);
            }
        }
        
        // Reverse the result vector to maintain original relative order
        reverse(ans.begin(), ans.end());
        
        return ans;
    }
};
