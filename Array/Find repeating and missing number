//TC=o(n)
//SC=o(n)
class Solution {
  public:
    vector<int> findTwoElement(vector<int>& arr) {
        // code here
        int n = arr.size();
        vector<bool>visited(n+1,false);//indexing is from 0 to n(total n+1 numbers)
        int repeated=-1;
        for(int i=0;i<n;i++){
            if(visited[arr[i]]==true){
                repeated=arr[i];
            }
            visited[arr[i]]=true;
        }
        
        int missing=-1;
        for(int i=1;i<=n;i++){
            if(visited[i]==false){
                missing=i;
                break;
            }
        }
        return {repeated,missing};
    }
};
