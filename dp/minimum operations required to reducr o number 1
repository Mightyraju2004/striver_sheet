#include <iostream>
#include <unordered_map>
#include <bits/stdc++.h>

using namespace std;

// Memory table to avoid duplicate calculations and stack overflow
unordered_map<long long, int> dp;

int getMinMoves(long long n) {
    // Base Case: Agar 1 soldier bacha hai, toh koi move nahi chahiye
    if (n == 1) return 0;
    
    // Agar ye number pehle se calculate ho chuka hai, toh direct return karo
    if (dp.find(n) != dp.end()) {
        return dp[n];
    }
    
    // Option 1: Reduce by 1 soldier
    int op1 = 1 + getMinMoves(n - 1);
    
    // Option 2: Reduce by half of its current soldiers, rounding down
    long long next_n2 = n - (n / 2);
    int op2 = 1 + getMinMoves(next_n2);
    
    // Option 3: Reduce by two-thirds of its current soldiers, rounding down
    long long next_n3 = n - ((2 * n) / 3);
    int op3 = 1 + getMinMoves(next_n3);
    
    // Teeno options mein se jo sabse minimum move de, use save karke return karo
    return dp[n] = min({op1, op2, op3});
}

int main() {
    // Fast I/O
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    long long n;
    if (cin >> n) {
        cout << getMinMoves(n) << "\n";
    }
    return 0;
}
