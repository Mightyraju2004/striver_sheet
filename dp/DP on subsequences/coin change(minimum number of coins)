class Solution {
public:
    int n;
    int t[13][10001]; // amount max 10000 hai to 10001 kaafi hai

    int solve(int i, vector<int>& coins, int amount) {
        // 1. BASE CASES
        if (amount == 0) return 0; // Amount ban gaya, 0 extra coins chahiye
        if (i == n) return 1e9;    // IMP: Coins khatam ho gaye par amount nahi bana (Impossible path)
        
        // 2. MEMOIZATION CHECK
        if (t[i][amount] != -1) return t[i][amount];
        
        // 3. SECURITY GUARD (SKIP)((Agar coin bada hai amount required se, toh sirf SKIP karo))
        if (coins[i] > amount) {
            return t[i][amount] = solve(i + 1, coins, amount);
        }
        
        // 4. TAKE & SKIP CHOICES
        int take = 1 + solve(i, coins, amount - coins[i]);//1 coin mil gya now aage explore karo.same coins can come again thats why index not change
        int skip = solve(i + 1, coins, amount);
        
        return t[i][amount] = min(take, skip);
    }

    int coinChange(vector<int>& coins, int amount) {
        n = coins.size();
        memset(t, -1, sizeof(t));
        
        int ans = solve(0, coins, amount);
        
        // Agar answer 1e9 ya usse bada hai, matlab koi combination nahi mila
        return (ans >= 1e9) ? -1 : ans;
    }
};
/*backtrack means apne pehle jaisi state pe aana*/
