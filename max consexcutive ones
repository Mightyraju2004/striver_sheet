class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int cnt=0,maxi=0;//maxi is max no of 1s i a streak
        for(int i=0;i<nums.size();i++){
            if(nums[i]==1){
                cnt++;
                maxi=max(cnt,maxi);
            }
            else
            cnt=0;//reset cnt if 0 isfounf
        }
        return maxi;    }
};
