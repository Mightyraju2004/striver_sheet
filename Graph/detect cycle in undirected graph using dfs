class Solution {
  public:
  bool iscycleDFS( unordered_map<int,vector<int>>&adj,int u,vector<bool>&visited,int parent){
      visited[u]=true;//u is visited now
      
      for(int &V:adj[u]){
          if(parent==V) continue;
          if(visited[V]) return true;//there is cycle
          if(iscycleDFS(adj,V,visited,u)) //now v is node and u is parent of v node
          return true;//there is cycle
      }
      return false;//there is no cycle//Return false only after checking ALL components
  }
  
    bool isCycle(int V, vector<vector<int>>& edges) {
        // Code here
        unordered_map<int,vector<int>>adj;
        
        //make adjency list
        for (auto& edge : edges) {
            int u = edge[0];
            int v = edge[1];
            adj[u].push_back(v);
            adj[v].push_back(u); // Because it is an undirected graph
        }
        
        vector<bool>visited(V,false);
        for(int i=0;i<V;i++){
            if(visited[i]==true) continue;
            if(visited[i]==false && iscycleDFS(adj,i,visited,-1)) return true;//i is node -1 is parent of i
        }
        return false;//Return false only after checking ALL components
    }
};
