class Solution {
public:
int n;
vector<vector<int>>result;
unordered_set<int>st;//humein duplicate elements (yaani same element ko baar-baar ek hi permutation mein use karne) se bachna hai thats why we use set
void solve(vector<int>& nums, vector<int>&temp){
    if(temp.size()==n){
        result.push_back(temp);
        return;
    }
    for(int i=0;i<n;i++){//har iteration i=0 se start hogi
        if(st.find(nums[i])==st.end()){
            temp.push_back(nums[i]);//do smt
            st.insert(nums[i]);//do smt
            solve(nums,temp);//mirror image  //explore         
            temp.pop_back();//backtrack
            st.erase(nums[i]);//backtrack
//Note=dont use function call here again after backtrack or popback because humne for loop lgaaya hua hai vo khud handle karlega.agr nahi lgaate for loop to khud se likhna hota
        }
    }
}
    vector<vector<int>> permute(vector<int>& nums) {
         n=nums.size();
        vector<int>temp;
        solve(nums,temp);
        return result;
    }
};
