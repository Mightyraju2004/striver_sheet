//Approach-1 (Using Bakctracking Khandani Template)
//Whenever a question asks for "Generating all possible" something, think about Backtracking once
//T.C : O(n * 2^n) - For a string of length n, there are 2^(𝑛 − 1) potential ways to partition it (since each position can either be a cut or not). and we also check palindrome O(n)
//S.C : O(n * 2^n) - Number of partitions * their length
class Solution {
public:
    int n;
    
    bool isPalindrome(string &s, int l, int r) {
        
        while(l < r) {
            if(s[l] != s[r])
                return false;
            l++;
            r--;
        }
        
        return true;
        
    }

    void backtrack(string &s, int idx, vector<string> curr, vector<vector<string>> &result) {
        
        if(idx == n) {
            result.push_back(curr);
            return;
        }
        
      /*  1. idx kya hai? (The Starting Point 📍)
idx hume batata hai ki pichle saare cuts lagne ke baad, string ka jo bacha hua hissa (remaining part) hai, woh kis index se shuru ho raha hai. Iska matlab idx se piche waali string ka faisla ho chuka hai, use ab touch nahi karna.

2. i kya hai? (The Cutting Knife 🔪)
i loop ke sath aage badhta hai. i ka kaam hai idx se lekar aage tak jaana aur ek-ek karke substring ka end point tay karna.
Jab loop i = idx par hai, toh substring bani s[idx...idx] (1 length ki).
Jab i badhkar idx + 1 hua, toh substring bani s[idx...idx+1] (2 length ki).
Jab i badhkar idx + 2 hua, toh substring bani s[idx...idx+2] (3 length ki).

*/
        for(int i = idx; i<n; i++) {
            
            if(isPalindrome(s, idx, i)) {//check s is panlindrome from idx to i th index
                
                curr.push_back(s.substr(idx, i-idx+1));//do something
                
                backtrack(s, i+1, curr, result);//explore
                
                curr.pop_back();//backtrack
                
            }
            
        }
        
    }
    
    vector<vector<string>> partition(string s) {
        n = s.length();
        vector<vector<string>> result;
        vector<string> curr;
        
        backtrack(s, 0, curr, result);//0 is index of s
        
        return result;
        
    }
};
