class Solution {
public:
    int minPairSum(vector<int>& nums) {
        //intuition is sabse bade element ko sabse chote ke saath add kardo
        //two pointer approach after sort
        //tc=o  of nlogn
        int n=nums.size();
        sort(nums.begin(),nums.end());
        int i=0,j=n-1;
        int maxi=0;
        while(i<j){
          int sum=nums[i]+nums[j];
          maxi=max(maxi,sum);
          i++;
          j--;
        }
        return maxi;
    }
};
